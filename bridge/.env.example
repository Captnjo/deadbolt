# Deadbolt Bridge Configuration
# Copy to .env and fill in values

# API token for authenticating agent requests (overrides config.json)
# DEADBOLT_API_TOKEN=db_your_token_here

# URL of the Swift app's embedded HTTP server
# DEADBOLT_UPSTREAM_URL=http://127.0.0.1:9876

# Port for the bridge to listen on
# DEADBOLT_BRIDGE_PORT=9877
